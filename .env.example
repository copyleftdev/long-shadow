# Copy this file to .env and fill in real values.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d
#
# Never commit your real .env file. .gitignore should exclude it (it does, in this repo).

# Required. A GitHub personal access token. No scopes needed if you're only
# watching public repos. Without one, you'll hit unauthenticated rate limits in
# minutes.
GITHUB_TOKEN=ghp_your_token_here

# Optional. Set to deliver alerts to Slack / Discord / your own endpoint.
# Without this, alerts only appear in `docker compose logs`.
WEBHOOK_URL=

# Optional. One of: generic | slack | discord
# Affects the JSON shape of the POST body. Default: generic (raw alerts JSON).
WEBHOOK_KIND=generic
